# OpenAI API Key (Required if using GPT models)
OPENAI_API_KEY=

# Anthropic API Key (Required if using Claude models)
ANTHROPIC_API_KEY=

# Google AI / Gemini API Key (Required if using Gemini models)
GOOGLE_API_KEY=

# Persistence Path
CHROMA_DB_PATH=./chroma_db

# Default LLM selection
DEFAULT_LLM=

# Groq API Key (Required if using Groq models)
GROQ_API_KEY=

# HuggingFace API Key (Required if using HuggingFace Inference API)
HUGGINGFACE_API_KEY=

# Ollama base URL (change if running on different host/port)
OLLAMA_BASE_URL=http://localhost:11434

# LM Studio base URL (default port is 1234)
LM_STUDIO_BASE_URL=http://localhost:1234
