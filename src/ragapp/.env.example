# OpenAI API Key (Required if using GPT models)
OPENAI_API_KEY=

# Anthropic API Key (Required if using Claude models)
ANTHROPIC_API_KEY=

# Google AI / Gemini API Key (Required if using Gemini models)
GOOGLE_API_KEY=

# Persistence Path
CHROMA_DB_PATH=./chroma_db

# Default LLM selection
DEFAULT_LLM=

# Groq API Key (Required if using Groq models)
GROQ_API_KEY=

# HuggingFace API Key (Required if using HuggingFace Inference API)
HUGGINGFACE_API_KEY=

# Ollama base URL (change if running on different host/port)
OLLAMA_BASE_URL=http://localhost:11434

# LM Studio base URL (default port is 1234)
LM_STUDIO_BASE_URL=http://localhost:1234

# --- Advanced Settings ---

# Target chunk size in characters for document parsing (default: 1000)
# Smaller = more precise retrieval, larger = more context per chunk
CHUNK_SIZE=1000

# Number of document chunks retrieved per query (default: 3)
N_RESULTS=3

# System prompt for LLM conversations (default: built-in research assistant prompt)
# SYSTEM_PROMPT=You are a helpful assistant...

# OpenAI embedding model name (default: text-embedding-3-small)
# WARNING: Changing this requires re-indexing all documents
EMBEDDING_MODEL=text-embedding-3-small

# HTTP timeout in seconds for model discovery calls (default: 3)
DISCOVERY_TIMEOUT=3
